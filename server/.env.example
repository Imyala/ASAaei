# ---------------------------------------------------------------------------
# ASAaei work-order middleware — environment configuration
# Copy this file to `.env` and fill in the real values for your network, OR
# export these variables in the process environment before `npm start`.
#
# NOTE: this service reads config from process.env only. It does NOT auto-load
# a .env file (no dotenv dependency, to keep deps minimal). Either export the
# vars in your shell / process manager, or `set -a; . ./.env; set +a` first.
# ---------------------------------------------------------------------------

# Port the middleware listens on.
PORT=8080

# CORS: which browser origin may call the GET endpoints.
# Default '*' is fine for a demo. In production set this to the exact origin
# the ASAaei PWA is served from, e.g. https://asaaei.internal.example.com
ALLOWED_ORIGIN=*

# Force mock mode on (no SAP / SharePoint needed). Any of "1", "true", "yes".
# If MOCK is unset, the service still runs in mock mode automatically whenever
# the SAP/SharePoint env vars below are not configured.
MOCK=1

# --- SAP (real mode) -------------------------------------------------------
# OData / Gateway service base URL that exposes the maintenance order header.
# TODO(IT): set this to your SAP Gateway OData service root, e.g.
#   https://sapgw.example.com/sap/opu/odata/sap/ZPM_ORDER_SRV
SAP_ODATA_URL=
# Basic-auth service account for the SAP OData call.
SAP_USER=
SAP_PASS=

# --- SharePoint Document Centre (real mode) --------------------------------
# Base URL of the Document Centre site collection.
# TODO(IT): confirm this matches your tenant.
SP_BASE_URL=https://orbit.hub.airservicesaustralia.com/sites/DocCentre
# Bearer token for the SharePoint REST/Search API (simplest auth to wire up).
# TODO(IT): supply an OAuth bearer token, OR replace with NTLM/cookie auth in
# index.js (see the clearly-commented hook there).
SP_BEARER=
